{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timing Lite",
  "version": "0.1.0",
  "identifier": "com.local.timinglite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Timing Lite",
        "width": 1200,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ]
  }
}
